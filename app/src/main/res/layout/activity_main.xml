<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:orientation="vertical">

    <!-- Top action bar -->
    <LinearLayout
        android:id="@+id/top_action_bar"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:gravity="center_vertical|end"
        android:orientation="horizontal"
        android:paddingEnd="8dp"
        android:paddingTop="4dp">
        <ImageButton android:id="@+id/btn_search"
            android:layout_width="44dp" android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_search"
            android:tint="#FFFFFF" android:contentDescription="Buscar"/>
        <ImageButton android:id="@+id/btn_filter"
            android:layout_width="44dp" android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_filter"
            android:tint="#FFFFFF" android:contentDescription="Filtrar"/>
        <ImageButton android:id="@+id/btn_trash"
            android:layout_width="44dp" android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_trash"
            android:tint="#FFFFFF" android:contentDescription="Papelera"/>
        <ImageButton android:id="@+id/btn_overflow"
            android:layout_width="44dp" android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_settings"
            android:tint="#FFFFFF" android:contentDescription="Ajustes"/>
    </LinearLayout>

    <!-- Search bar -->
    <LinearLayout android:id="@+id/search_bar"
        android:layout_width="match_parent" android:layout_height="52dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingStart="16dp" android:paddingEnd="16dp"
        android:background="#1C1C1E" android:visibility="gone">
        <EditText android:id="@+id/search_input"
            android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1"
            android:background="@drawable/bg_search_dark"
            android:hint="Buscar archivos..."
            android:textColor="#FFFFFF"
            android:imeOptions="actionSearch" android:inputType="text"
            android:paddingStart="12dp" android:paddingEnd="12dp"
            android:singleLine="true" android:textSize="14sp"/>
        <ProgressBar
            android:id="@+id/search_progress"
            style="?android:attr/progressBarStyleSmall"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginStart="8dp"
            android:indeterminate="true"
            android:visibility="gone"/>
        <TextView
            android:id="@+id/search_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="Buscando..."
            android:textColor="#888888"
            android:textSize="12sp"
            android:visibility="gone"/>
        <TextView
            android:id="@+id/btn_cancel_search"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:text="Cancelar"
            android:textColor="#1E88E5"
            android:textSize="13sp"
            android:textStyle="bold"
            android:visibility="gone"/>
    </LinearLayout>

    <!-- Main content: FrameLayout so Storage/Recent can swap -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- ===== STORAGE VIEW ===== -->
        <LinearLayout
            android:id="@+id/view_storage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Page title -->
            <TextView android:id="@+id/page_title"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginStart="20dp" android:layout_marginTop="6dp"
                android:layout_marginBottom="4dp" android:text="Almacenamiento"
                android:textColor="#FFFFFF" android:textSize="30sp" android:textStyle="bold"/>

            <!-- Section header row -->
            <LinearLayout
                android:layout_width="match_parent" android:layout_height="40dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="20dp" android:paddingEnd="8dp">
                <TextView android:id="@+id/section_header_label"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Almacenamiento interno"
                    android:textColor="#1E88E5" android:textSize="13sp" android:textStyle="bold"
                    android:ellipsize="end" android:maxLines="1"/>
                <ImageButton android:id="@+id/btn_new_folder_inline"
                    android:layout_width="38dp" android:layout_height="38dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_add_folder" android:tint="#FFFFFF"
                    android:contentDescription="Nueva carpeta"/>
            </LinearLayout>

            <!-- Breadcrumb -->
            <HorizontalScrollView android:id="@+id/breadcrumb_scroll"
                android:layout_width="match_parent" android:layout_height="28dp"
                android:scrollbars="none" android:paddingStart="20dp"
                android:paddingEnd="16dp" android:visibility="gone">
                <LinearLayout android:id="@+id/breadcrumb_container"
                    android:layout_width="wrap_content" android:layout_height="match_parent"
                    android:gravity="center_vertical" android:orientation="horizontal"/>
            </HorizontalScrollView>

            <TextView
                android:id="@+id/loading_status_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="20dp"
                android:paddingEnd="16dp"
                android:paddingBottom="6dp"
                android:text="Cargando..."
                android:textColor="#888888"
                android:textSize="12sp"
                android:visibility="gone"/>

            <!-- Paste bar -->
            <LinearLayout android:id="@+id/paste_bar"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="20dp" android:paddingEnd="8dp"
                android:background="#1A2744" android:visibility="gone">
                <ImageView android:layout_width="20dp" android:layout_height="20dp"
                    android:src="@drawable/ic_paste" android:tint="#1E88E5"
                    android:layout_marginEnd="10dp"/>
                <TextView android:id="@+id/paste_label"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:textColor="#CCCCCC"
                    android:textSize="13sp" android:ellipsize="end" android:maxLines="1"/>
                <Button android:id="@+id/btn_paste"
                    android:layout_width="wrap_content" android:layout_height="36dp"
                    android:layout_gravity="center_vertical"
                    android:text="Pegar" android:textColor="#FFFFFF" android:textSize="13sp"
                    android:textAllCaps="false"
                    android:minHeight="0dp"
                    android:background="@drawable/bg_paste_btn"
                    android:paddingTop="0dp"
                    android:paddingBottom="0dp"
                    android:paddingStart="14dp" android:paddingEnd="14dp"/>
                <ImageButton android:id="@+id/btn_paste_dismiss"
                    android:layout_width="36dp" android:layout_height="36dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    android:tint="#666666" android:contentDescription="Cancelar"/>
            </LinearLayout>

            <!-- FrameLayout: RecyclerView + empty state overlap correctly -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
                    android:id="@+id/swipe_refresh"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recycler"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"/>
                </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

                <!-- Empty state overlaid in same FrameLayout -->
                <LinearLayout android:id="@+id/empty_view"
                    android:layout_width="match_parent" android:layout_height="match_parent"
                    android:gravity="center" android:orientation="vertical"
                    android:visibility="gone">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="&#128193;" android:textSize="56sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="8dp" android:text="Esta carpeta esta vacia"
                        android:textColor="#666666" android:textSize="15sp"/>
                </LinearLayout>

            </FrameLayout>

        </LinearLayout>

        <!-- ===== RECENT VIEW ===== -->
        <LinearLayout android:id="@+id/view_recent"
            android:layout_width="match_parent" android:layout_height="match_parent"
            android:orientation="vertical" android:visibility="gone">

            <TextView android:id="@+id/recent_title" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginStart="20dp" android:layout_marginTop="6dp"
                android:layout_marginBottom="8dp" android:text="Recientes"
                android:textColor="#FFFFFF" android:textSize="30sp" android:textStyle="bold"/>

            <FrameLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">

                <!-- Empty recents -->
                <LinearLayout android:id="@+id/empty_recent_view"
                    android:layout_width="match_parent" android:layout_height="match_parent"
                    android:gravity="center" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="&#128337;" android:textSize="64sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Los ficheros recientes apareceran aqui"
                        android:textColor="#666666" android:textSize="15sp" android:gravity="center"
                        android:paddingStart="40dp" android:paddingEnd="40dp"/>
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_recent"
                    android:layout_width="match_parent" android:layout_height="match_parent"
                    android:paddingBottom="8dp" android:clipToPadding="false"
                    android:visibility="gone"/>

            </FrameLayout>

        </LinearLayout>

    </FrameLayout>

    <LinearLayout
        android:id="@+id/selection_actions_bar"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="2dp"
        android:paddingEnd="2dp"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/action_send"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackground">
            <ImageView
                android:id="@+id/action_send_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_action_send"
                android:tint="#FFFFFF"/>
            <TextView
                android:id="@+id/action_send_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Enviar"
                android:textColor="#FFFFFF"
                android:textSize="12sp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/action_move"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackground">
            <ImageView
                android:id="@+id/action_move_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_action_move"
                android:tint="#FFFFFF"/>
            <TextView
                android:id="@+id/action_move_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Mover"
                android:textColor="#FFFFFF"
                android:textSize="12sp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/action_copy"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackground">
            <ImageView
                android:id="@+id/action_copy_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_action_copy"
                android:tint="#FFFFFF"/>
            <TextView
                android:id="@+id/action_copy_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Copiar"
                android:textColor="#FFFFFF"
                android:textSize="12sp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/action_delete"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackground">
            <ImageView
                android:id="@+id/action_delete_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_trash"
                android:tint="#FFFFFF"/>
            <TextView
                android:id="@+id/action_delete_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Eliminar"
                android:textColor="#FFFFFF"
                android:textSize="12sp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/action_rename"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackground">
            <ImageView
                android:id="@+id/action_rename_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_action_rename"
                android:tint="#FFFFFF"/>
            <TextView
                android:id="@+id/action_rename_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Renombrar"
                android:textColor="#FFFFFF"
                android:textSize="12sp"/>
        </LinearLayout>

    </LinearLayout>

    <!-- Bottom Navigation — custom, no Material dependency -->
    <LinearLayout
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#111111"
        android:orientation="horizontal">

        <!-- Recientes tab -->
        <LinearLayout
            android:id="@+id/tab_recent"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackground">
            <ImageView
                android:id="@+id/tab_recent_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_recent"
                android:tint="#666666"/>
            <TextView
                android:id="@+id/tab_recent_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recientes"
                android:textSize="10sp"
                android:textColor="#666666"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- Almacenamiento tab -->
        <LinearLayout
            android:id="@+id/tab_storage"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackground">
            <ImageView
                android:id="@+id/tab_storage_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_storage"
                android:tint="#1E88E5"/>
            <TextView
                android:id="@+id/tab_storage_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Almacenamiento"
                android:textSize="10sp"
                android:textColor="#1E88E5"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
