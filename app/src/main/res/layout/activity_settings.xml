<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/settings_root"
    android:orientation="vertical"
    android:background="?android:attr/windowBackground">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="12dp">
        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
            android:tint="?android:attr/textColorPrimary"
            android:contentDescription="Volver"/>
        <TextView
            android:id="@+id/settings_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Ajustes"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="20sp"
            android:textStyle="bold"/>

            <TextView
                android:id="@+id/settings_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_settings_badge"
                android:paddingStart="8dp"
                android:paddingTop="2dp"
                android:paddingEnd="8dp"
                android:paddingBottom="2dp"
                android:text="Personaliza"
                android:textColor="?android:attr/textColorSecondary"
                android:textSize="11sp"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="?android:attr/windowBackground">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingBottom="24dp">

            <!-- Section: Apariencia -->
            <TextView
                android:id="@+id/label_appearance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="20dp"
                android:paddingTop="20dp"
                android:paddingBottom="8dp"
                android:text="APARIENCIA"
                android:textColor="?attr/colorPrimary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"/>

            <!-- Theme selector -->
            <LinearLayout
                android:id="@+id/row_theme"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_settings_card"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="20dp"
                android:paddingEnd="20dp">
                <ImageView
                    android:id="@+id/theme_icon"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_theme"
                    android:tint="?android:attr/textColorPrimary"
                    android:layout_marginEnd="16dp"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/theme_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tema"
                        android:textColor="?android:attr/textColorPrimary"
                        android:textSize="15sp"/>
                    <TextView
                        android:id="@+id/theme_subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Oscuro"
                        android:textColor="?android:attr/textColorSecondary"
                        android:textSize="13sp"/>
                </LinearLayout>
                <ImageView
                    android:id="@+id/theme_chevron"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_right"
                    android:tint="?android:attr/textColorSecondary"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/row_ui_scale"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_settings_card"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="20dp"
                android:paddingEnd="20dp">
                <ImageView
                    android:id="@+id/ui_scale_icon"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_marginEnd="16dp"
                    android:src="@drawable/ic_filter"
                    android:tint="?android:attr/textColorPrimary"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/ui_scale_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tamano de interfaz"
                        android:textColor="?android:attr/textColorPrimary"
                        android:textSize="15sp"/>
                    <TextView
                        android:id="@+id/ui_scale_subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Normal"
                        android:textColor="?android:attr/textColorSecondary"
                        android:textSize="13sp"/>
                </LinearLayout>
                <ImageView
                    android:id="@+id/ui_scale_chevron"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_right"
                    android:tint="?android:attr/textColorSecondary"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/row_default_apps"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_settings_card"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="20dp"
                android:paddingEnd="20dp">
                <ImageView
                    android:id="@+id/default_apps_icon"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_marginEnd="16dp"
                    android:src="@drawable/ic_recent"
                    android:tint="?android:attr/textColorPrimary"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/default_apps_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Apps por defecto"
                        android:textColor="?android:attr/textColorPrimary"
                        android:textSize="15sp"/>
                    <TextView
                        android:id="@+id/default_apps_subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sin apps registradas"
                        android:textColor="?android:attr/textColorSecondary"
                        android:textSize="13sp"/>
                </LinearLayout>
                <ImageView
                    android:id="@+id/default_apps_chevron"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_right"
                    android:tint="?android:attr/textColorSecondary"/>
            </LinearLayout>

            <!-- Section: Acerca de -->
            <TextView
                android:id="@+id/label_about"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="20dp"
                android:paddingTop="24dp"
                android:paddingBottom="8dp"
                android:text="ACERCA DE"
                android:textColor="?attr/colorPrimary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_settings_card"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Versión"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textSize="15sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1.0"
                    android:textColor="?android:attr/textColorSecondary"
                    android:textSize="14sp"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
