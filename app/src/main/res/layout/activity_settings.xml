<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/settings_root"
    android:orientation="vertical"
    android:background="?android:attr/windowBackground">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="12dp">
        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
            android:tint="?android:attr/textColorPrimary"
            android:contentDescription="@string/back"/>
        <TextView
            android:id="@+id/settings_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/settings"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="20sp"
            android:textStyle="bold"/>

            <TextView
                android:id="@+id/settings_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_settings_badge"
                android:paddingStart="8dp"
                android:paddingTop="2dp"
                android:paddingEnd="8dp"
                android:paddingBottom="2dp"
                android:text="@string/customize"
                android:textColor="?android:attr/textColorSecondary"
                android:textSize="11sp"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="?android:attr/windowBackground">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingBottom="24dp">

            <!-- Section: Appearance -->
            <TextView
                android:id="@+id/label_appearance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="20dp"
                android:paddingTop="20dp"
                android:paddingBottom="8dp"
                android:text="@string/appearance_upper"
                android:textColor="?attr/colorPrimary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"/>

            <!-- Theme selector -->
            <LinearLayout
                android:id="@+id/row_theme"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_settings_card"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="20dp"
                android:paddingEnd="20dp">
                <ImageView
                    android:id="@+id/theme_icon"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_theme"
                    android:tint="?android:attr/textColorPrimary"
                    android:layout_marginEnd="16dp"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/theme_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/theme_title"
                        android:textColor="?android:attr/textColorPrimary"
                        android:textSize="15sp"/>
                    <TextView
                        android:id="@+id/theme_subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/theme_dark"
                        android:textColor="?android:attr/textColorSecondary"
                        android:textSize="13sp"/>
                </LinearLayout>
                <ImageView
                    android:id="@+id/theme_chevron"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_right"
                    android:tint="?android:attr/textColorSecondary"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/row_ui_scale"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_settings_card"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="20dp"
                android:paddingEnd="20dp">
                <ImageView
                    android:id="@+id/ui_scale_icon"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_marginEnd="16dp"
                    android:src="@drawable/ic_filter"
                    android:tint="?android:attr/textColorPrimary"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/ui_scale_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/ui_scale_title"
                        android:textColor="?android:attr/textColorPrimary"
                        android:textSize="15sp"/>
                    <TextView
                        android:id="@+id/ui_scale_subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/ui_scale_normal"
                        android:textColor="?android:attr/textColorSecondary"
                        android:textSize="13sp"/>
                </LinearLayout>
                <ImageView
                    android:id="@+id/ui_scale_chevron"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_right"
                    android:tint="?android:attr/textColorSecondary"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/row_language"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_settings_card"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="20dp"
                android:paddingEnd="20dp">
                <ImageView
                    android:id="@+id/language_icon"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_marginEnd="16dp"
                    android:src="@drawable/ic_language"
                    android:tint="?android:attr/textColorPrimary"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/language_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/language_title"
                        android:textColor="?android:attr/textColorPrimary"
                        android:textSize="15sp"/>
                    <TextView
                        android:id="@+id/language_subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/language_english"
                        android:textColor="?android:attr/textColorSecondary"
                        android:textSize="13sp"/>
                </LinearLayout>
                <ImageView
                    android:id="@+id/language_chevron"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_right"
                    android:tint="?android:attr/textColorSecondary"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/row_default_apps"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_settings_card"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="20dp"
                android:paddingEnd="20dp">
                <ImageView
                    android:id="@+id/default_apps_icon"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_marginEnd="16dp"
                    android:src="@drawable/ic_recent"
                    android:tint="?android:attr/textColorPrimary"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/default_apps_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/default_apps_title"
                        android:textColor="?android:attr/textColorPrimary"
                        android:textSize="15sp"/>
                    <TextView
                        android:id="@+id/default_apps_subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/default_apps_none"
                        android:textColor="?android:attr/textColorSecondary"
                        android:textSize="13sp"/>
                </LinearLayout>
                <ImageView
                    android:id="@+id/default_apps_chevron"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_right"
                    android:tint="?android:attr/textColorSecondary"/>
            </LinearLayout>

            <!-- Section: About -->
            <TextView
                android:id="@+id/label_about"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="20dp"
                android:paddingTop="24dp"
                android:paddingBottom="8dp"
                android:text="@string/about_upper"
                android:textColor="?attr/colorPrimary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_settings_card"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/version"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textSize="15sp"/>
                <TextView
                    android:id="@+id/version_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-"
                    android:textColor="?android:attr/textColorSecondary"
                    android:textSize="14sp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/row_quick_guide"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_settings_card"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="20dp"
                android:paddingEnd="20dp">
                <ImageView
                    android:id="@+id/quick_guide_icon"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_marginEnd="16dp"
                    android:src="@drawable/ic_file"
                    android:tint="?android:attr/textColorPrimary"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/quick_guide_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/quick_guide_title"
                        android:textColor="?android:attr/textColorPrimary"
                        android:textSize="15sp"/>
                    <TextView
                        android:id="@+id/quick_guide_subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/quick_guide_subtitle"
                        android:textColor="?android:attr/textColorSecondary"
                        android:textSize="13sp"/>
                </LinearLayout>
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_right"
                    android:tint="?android:attr/textColorSecondary"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/row_github"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_settings_card"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="20dp"
                android:paddingEnd="20dp">
                <ImageView
                    android:id="@+id/github_icon"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_marginEnd="16dp"
                    android:src="@drawable/ic_more"
                    android:tint="?android:attr/textColorPrimary"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/github_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/github_title"
                        android:textColor="?android:attr/textColorPrimary"
                        android:textSize="15sp"/>
                    <TextView
                        android:id="@+id/github_subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/github_subtitle"
                        android:textColor="?android:attr/textColorSecondary"
                        android:textSize="13sp"/>
                </LinearLayout>
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_right"
                    android:tint="?android:attr/textColorSecondary"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
