<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="AppTheme" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#1E88E5</item>
        <item name="colorPrimaryDark">#1565C0</item>
        <item name="colorAccent">#1E88E5</item>
        <item name="colorSurface">#1C1C1E</item>
        <item name="colorOnSurface">#FFFFFF</item>
        <item name="android:windowBackground">#000000</item>
        <item name="android:statusBarColor">#000000</item>
        <item name="android:navigationBarColor">#111111</item>
        <item name="android:textColorPrimary">#FFFFFF</item>
        <item name="android:textColorSecondary">#888888</item>
    </style>

    <style name="AppTheme.Light" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">#1565C0</item>
        <item name="colorPrimaryDark">#0D47A1</item>
        <item name="colorAccent">#1565C0</item>
        <item name="colorSurface">#FFFFFF</item>
        <item name="colorOnSurface">#1C1C1E</item>
        <item name="android:windowBackground">#F2F2F7</item>
        <item name="android:statusBarColor">#DCE3EC</item>
        <item name="android:navigationBarColor">#FFFFFF</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:textColorPrimary">#1C1C1E</item>
        <item name="android:textColorSecondary">#6B6B6B</item>
    </style>

    <style name="AppTheme.Dark" parent="AppTheme"/>

    <style name="CategoryCard">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">64dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:paddingStart">14dp</item>
        <item name="android:paddingEnd">14dp</item>
        <item name="android:background">@drawable/bg_category_card</item>
    </style>

</resources>
